---
import { ClientRouter } from 'astro:transitions';
import type { BaseHeadProps, WithContext, Thing } from '@/types';
import BaseHead from '@/components/BaseHead.astro';
import BackToTop from '@/components/BackToTop.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import JsonLd from '@/components/JsonLd.astro';
import siteConfig from '@/data/site-config';
import {
  generateBreadcrumbItems,
  generateBreadcrumbStructuredData,
  shouldShowBreadcrumbs,
} from '@/utils/breadcrumb-utils';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BreadcrumbList from '@/components/ui/BreadcrumbList.astro';
import BreadcrumbItem from '@/components/ui/BreadcrumbItem.astro';
import BreadcrumbLink from '@/components/ui/BreadcrumbLink.astro';
import BreadcrumbPage from '@/components/ui/BreadcrumbPage.astro';
import BreadcrumbSeparator from '@/components/ui/BreadcrumbSeparator.astro';
import { createWebSiteSchema, createWebPageSchema, createPersonSchema } from '@/utils/schema-utils';

export type Props = BaseHeadProps & {
  showBreadcrumbs?: boolean;
  includePersonSchema?: boolean;
  customSchemas?: WithContext<Thing>[];
  lang?: string;
};

const props = Astro.props;
const { showBreadcrumbs = true, includePersonSchema = false, customSchemas = [], lang = 'en' } = props;
const { ...head } = props;

const siteUrl = Astro.site?.toString() || import.meta.env.SITE_URL || 'https://nhutduong.com';
const canonicalUrl = new URL(
  Astro.request.url,
  Astro.site || import.meta.env.SITE_URL || 'https://nhutduong.com'
).toString();

const shouldShow = showBreadcrumbs && shouldShowBreadcrumbs(Astro.url.pathname);
const breadcrumbItems = shouldShow ? await generateBreadcrumbItems(Astro.url.pathname) : [];
const breadcrumbStructuredData = shouldShow
  ? generateBreadcrumbStructuredData(breadcrumbItems, Astro.url.pathname, siteUrl)
  : null;

const schemas: WithContext<Thing>[] = [
  createWebSiteSchema(siteUrl),
  createWebPageSchema(
    canonicalUrl,
    head.title || siteConfig.title,
    head.description || siteConfig.description,
    new Date()
  ),
];

if (includePersonSchema) {
  schemas.push(createPersonSchema());
}

if (customSchemas.length > 0) {
  schemas.push(...customSchemas);
}
---

<!doctype html>
<html lang={lang} class="wrap-break-word antialiased">
  <head>
    <BaseHead {...head} />
    <JsonLd schema={schemas} />
    {
      breadcrumbStructuredData && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbStructuredData)} />
      )
    }
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <a
      href="#main"
      class="bg-primary text-primary-foreground focus-visible:ring-ring sr-only fixed top-0 left-0 z-50 block w-full rounded-none px-4 py-3 text-center text-sm font-medium shadow focus:not-sr-only focus-visible:ring-2 focus-visible:outline-none sm:top-4 sm:left-4 sm:w-auto sm:rounded-md"
    >
      Skip to content
    </a>
    <div class="flex min-h-screen flex-col px-4 md:px-8">
      <div transition:persist>
        <Header />
      </div>
      <main
        id="main"
        class="prose sm:prose-lg mx-auto w-full max-w-5xl grow pt-6 pb-12 sm:pt-8 sm:pb-14 lg:pt-10 lg:pb-16"
      >
        {
          shouldShow && (
            <div class="not-prose mb-6">
              <Breadcrumb class="py-2">
                <BreadcrumbList>
                  {breadcrumbItems.map((item, index) => (
                    <>
                      <BreadcrumbItem>
                        {item.href ? (
                          <BreadcrumbLink href={item.href}>{item.label}</BreadcrumbLink>
                        ) : (
                          <BreadcrumbPage>{item.label}</BreadcrumbPage>
                        )}
                      </BreadcrumbItem>
                      {index < breadcrumbItems.length - 1 && <BreadcrumbSeparator />}
                    </>
                  ))}
                </BreadcrumbList>
              </Breadcrumb>
            </div>
          )
        }
        <slot />
      </main>
      <div transition:persist>
        <Footer />
      </div>
    </div>
    <BackToTop />
  </body>
</html>

---
import siteConfig from '@/data/site-config';
import NavLink from '@/components/NavLink.astro';
import Search from '@/components/Search.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import Icon from '@/components/Icon.astro';

const navLinks = siteConfig.primaryNavLinks || [];
---

<div class="flex items-center gap-1 md:gap-2">
  <nav class="hidden items-center gap-1 md:flex md:gap-2 lg:gap-4" aria-label="Primary">
    {navLinks.map((link) => <NavLink href={link.href}>{link.text}</NavLink>)}
  </nav>

  <Search />

  <button
    type="button"
    id="mobile-nav-toggle"
    aria-label="Open Menu"
    aria-expanded="false"
    aria-controls="mobile-nav"
    class="hover:bg-accent hover:text-accent-foreground focus-visible:ring-ring inline-flex h-9 w-9 items-center justify-center rounded-md transition-colors focus-visible:ring-1 focus-visible:outline-none md:hidden"
  >
    <Icon icon="menu" class="h-5 w-5" />
  </button>

  <ThemeToggle />
</div>

<div
  id="mobile-nav"
  data-open="false"
  class="bg-background/95 supports-[backdrop-filter]:bg-background/80 fixed inset-0 z-30 hidden backdrop-blur md:hidden"
>
  <div class="mx-auto flex h-full max-w-5xl flex-col gap-6 px-4 pt-24">
    <button
      type="button"
      id="mobile-nav-close"
      aria-label="Close Menu"
      class="hover:bg-accent hover:text-accent-foreground focus-visible:ring-ring absolute top-5 right-4 inline-flex h-9 w-9 items-center justify-center rounded-md transition-colors focus-visible:ring-1 focus-visible:outline-none"
    >
      <Icon icon="close" class="h-5 w-5" />
    </button>
    <nav class="flex flex-col gap-1 text-lg" aria-label="Mobile Primary">
      {
        navLinks.map((link) => (
          <NavLink href={link.href} class="h-12 text-base">
            {link.text}
          </NavLink>
        ))
      }
    </nav>
  </div>
</div>

<script>
  function initMobileNav() {
    const toggle = document.getElementById('mobile-nav-toggle');
    const close = document.getElementById('mobile-nav-close');
    const panel = document.getElementById('mobile-nav');
    if (!toggle || !close || !panel) return;

    const setOpen = (open: boolean) => {
      panel.dataset.open = open ? 'true' : 'false';
      panel.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    };

    const onToggle = () => setOpen(panel.dataset.open !== 'true');
    const onClose = () => setOpen(false);
    const onKey = (e: KeyboardEvent) => {
      if (e.key === 'Escape') setOpen(false);
    };
    const onLinkClick = (e: MouseEvent) => {
      const target = e.target as HTMLElement | null;
      if (target?.closest('a')) setOpen(false);
    };

    toggle.addEventListener('click', onToggle);
    close.addEventListener('click', onClose);
    document.addEventListener('keydown', onKey);
    panel.addEventListener('click', onLinkClick);
  }

  document.addEventListener('astro:page-load', initMobileNav);
</script>

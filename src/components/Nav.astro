---
import siteConfig from "@/data/site-config";
import NavLink from "@/components/NavLink.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";

const navLinks = siteConfig.primaryNavLinks || [];
---

<nav class="flex items-center">
  {
    navLinks.length > 0 && (
      <div class="pr-4">
        <ul class="flex gap-4">
          {navLinks.map((link) => (
            <li>
              <NavLink
                class="py-1 font-medium text-zinc-600 hover:text-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200"
                href={link.href}
              >
                {link.text}
              </NavLink>
            </li>
          ))}
        </ul>
      </div>
    )
  }
  <ThemeToggle />
</nav>

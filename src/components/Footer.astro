---
import siteConfig from '@/data/site-config';
import SocialLink from '@/components/SocialLink.astro';

const currentYear = new Date().getFullYear();
const socialLinks = siteConfig.socialLinks || [];
const navLinks = siteConfig.primaryNavLinks || [];
---

<footer class="border-border mx-auto w-full max-w-5xl border-t pt-8 pb-12 sm:pt-10">
  <div class="grid gap-8 sm:grid-cols-3 sm:gap-10">
    <div class="space-y-2 sm:col-span-2">
      <p class="font-serif text-base font-medium">{siteConfig.title}</p>
      <p class="text-foreground/70 m-0 max-w-md text-sm">
        {siteConfig.description}
      </p>
    </div>
    <div class="space-y-3">
      <p class="text-foreground/60 m-0 text-xs font-medium tracking-wider uppercase">Navigate</p>
      <ul class="m-0 flex list-none flex-col gap-2 p-0 text-sm">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-foreground/80 text-foreground/70 transition-colors">
                {link.text}
              </a>
            </li>
          ))
        }
        <li>
          <a href="/rss.xml" class="hover:text-foreground/80 text-foreground/70 transition-colors"> RSS </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="mt-8 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
    <p class="text-muted-foreground m-0 text-xs">
      &copy; {currentYear}
      {siteConfig.title}. Built with Astro.
    </p>
    {
      socialLinks.length > 0 && (
        <div class="flex items-center gap-1">
          {(siteConfig.socialLinks || []).map((link) => (
            <SocialLink {...link} />
          ))}
        </div>
      )
    }
  </div>
</footer>

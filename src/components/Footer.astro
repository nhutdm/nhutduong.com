---
import siteConfig from "../data/site-config";

const currentYear = new Date().getFullYear();
---

<footer class="w-full max-w-4xl mx-auto py-8">
  <div class="flex justify-center">
    <p class="text-xs text-zinc-600 dark:text-zinc-400">
      &#169; {currentYear}
      {siteConfig.title}
    </p>
  </div>
</footer>

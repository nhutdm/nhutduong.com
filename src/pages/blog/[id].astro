---
import { getCollection, render } from 'astro:content';
import type { BlogPost } from '@/types';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import Comments from '@/components/Comments.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import ShareLinks from '@/components/ShareLinks.astro';
import TOC from '@/components/TOC.astro';
import { slugify } from '@/utils/common-utils';
import { sortItemsByDateDesc } from '@/utils/data-utils';
import { createBlogPostingSchema, createPersonSchema } from '@/utils/schema-utils';
import { readingTime, formatReadingTime } from '@/utils/reading-utils';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
  return posts.map((post) => ({
    params: { id: post.id },
    props: {
      post,
    },
  }));
}

type Props = { post: BlogPost };

const { post } = Astro.props;
const { title, publishDate, updatedDate, excerpt, tags = [], seo } = post.data;
const ogImage = { src: new URL(`og/${post.id}.png`, Astro.site).toString(), alt: title };
const { Content, headings } = await render(post);

const postUrl = new URL(`/blog/${post.id}`, Astro.site).toString();
const authorSchema = createPersonSchema();
const blogPostingSchema = createBlogPostingSchema(post, postUrl, authorSchema);
const minutes = readingTime(post.body);
const tocItems = headings.filter((h) => h.depth >= 2);
---

<BaseLayout
  title={seo?.title ?? title}
  description={seo?.description ?? excerpt}
  image={seo?.image ?? ogImage}
  pageType="article"
  customSchemas={[blogPostingSchema]}
  preconnect={['https://giscus.app']}
>
  <header class="mx-auto max-w-3xl">
    <h1 class="mt-0 text-3xl sm:text-4xl">{title}</h1>
    <div
      class="text-foreground/60 mt-4 flex flex-col gap-2 text-sm sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-3"
    >
      <span>
        {
          updatedDate ? (
            <>
              Updated on <FormattedDate date={updatedDate} />
            </>
          ) : (
            <>
              Published on <FormattedDate date={publishDate} />
            </>
          )
        }
      </span>
      {
        minutes > 1 && (
          <>
            <span aria-hidden="true" class="text-foreground/40 hidden sm:inline">
              ·
            </span>
            <span>{formatReadingTime(minutes)}</span>
          </>
        )
      }
      <span class="sm:ml-auto">
        <ShareLinks title={title} url={postUrl} />
      </span>
    </div>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap items-center gap-1.5">
          {tags.map((tag) => (
            <Badge variant="outline" class="text-foreground/70 px-2 py-0 text-xs font-normal">
              <a href={`/tags/${slugify(tag)}`}>{tag}</a>
            </Badge>
          ))}
        </div>
      )
    }
  </header>
  {
    tocItems.length > 0 && (
      <details class="not-prose border-border bg-muted/40 mt-8 rounded-lg border p-4 lg:hidden">
        <summary class="cursor-pointer text-sm font-medium">Table of contents</summary>
        <TOC headings={headings} class="mt-4 block" />
      </details>
    )
  }
  <div class="lg:flex lg:items-start lg:gap-10">
    {
      tocItems.length > 0 && (
        <TOC headings={headings} class="not-prose sticky top-20 order-2 hidden pt-6 lg:block lg:w-64 lg:shrink-0" />
      )
    }
    <article class="lg:max-w-2xl lg:grow">
      <div id="content">
        <Content />
      </div>
    </article>
  </div>
  <Comments />
</BaseLayout>

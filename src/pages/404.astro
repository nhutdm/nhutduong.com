---
import { SITE } from "@config";
import Layout from "../layouts/Layout.astro";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <section class="flex flex-1 items-center justify-center">
    <div
      class="prose sm:prose-lg prose-zinc dark:prose-invert w-full max-w-3xl px-4 py-12"
    >
      <h1>Ooops!</h1>
      <h2>Page Not Found</h2>
      <p>The page you are looking for does not exist.</p>
      <button
        class="bg-zinc-900 hover:bg-zinc-800 dark:bg-zinc-200 dark:hover:bg-zinc-100 py-2 px-4 rounded-full mt-12 sm:mt-16"
      >
        <a class="no-underline text-sm text-zinc-50 dark:text-zinc-900" href="/"
          >Back to home</a
        >
      </button>
    </div>
  </section>
</Layout>
